{
  "name": "orgonite-chat-node",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npx tsx watch server/src/index.ts\" \"npm --prefix client run dev\"",
    "build": "node scripts/build-legacy-client.cjs && npx tsc -p server/tsconfig.json",
    "start": "node server.js",
    "typecheck": "npx tsc --noEmit -p server/tsconfig.json && npx tsc --noEmit -p packages/shared/tsconfig.json",
    "test": "npx vitest run --passWithNoTests --root server"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "uuid": "^11.1.0",
    "ws": "^8.21.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
